@{
    Layout = "/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Series · Admin";

    // Series CRUD
    var urlGetAll = Url.Action("GetAll", "Series", new { area = "Admin" });
    var urlAdd = Url.Action("AddSeries", "Series", new { area = "Admin" });
    var urlUpdate = Url.Action("UpdateSeries", "Series", new { area = "Admin" });
    var urlDelete = Url.Action("Delete", "Series", new { area = "Admin" });

    // Genres + SeriesGenre
    var urlGenresGetAll = Url.Action("GetAll", "Genres", new { area = "Admin" });
    var urlSGGetBySeries = Url.Action("GetBySeries", "SeriesGenre", new { area = "Admin" });
    var urlSGAdd = Url.Action("Add", "SeriesGenre", new { area = "Admin" });
    var urlSGDelete = Url.Action("Delete", "SeriesGenre", new { area = "Admin" });
}

<style>
    .loading-overlay {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 1100;
        background: rgba(0,0,0,.25);
        backdrop-filter: blur(1px);
    }

    .loading-overlay .spinner-wrap {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        background: rgba(0,0,0,.35);
        padding: 16px 18px;
        border-radius: 10px;
    }

    .spinner {
        width: 52px;
        height: 52px;
        border: 5px solid #eee;
        border-top: 5px solid #27d3c3;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0); }
        to { transform: rotate(360deg); }
    }

    .toastx {
        position: fixed;
        top: 18px;
        right: 18px;
        min-width: 280px;
        z-index: 1200;
        background: #333;
        color: #fff;
        border-radius: 10px;
        padding: 12px 16px;
        display: none;
        box-shadow: 0 8px 24px rgba(0,0,0,.25);
    }

    .toastx.success { background: #28a745; }
    .toastx.error { background: #dc3545; }

    .chip {
        display: inline-block;
        padding: .15rem .5rem;
        border-radius: 1rem;
        font-size: .775rem;
        background: var(--bs-secondary-bg);
        color: var(--bs-body-color);
    }

    .sg-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        margin: 0 .4rem .4rem 0;
        padding: .4rem .55rem;
    }

    .sg-chip .btn {
        --bs-btn-padding-y: .05rem;
        --bs-btn-padding-x: .28rem;
    }
</style>

<div class="loading-overlay" id="__loadingOverlay">
    <div class="spinner-wrap"><div class="spinner"></div></div>
</div>

<div class="toastx" id="__toastMessage"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h4 class="m-0"><i class="bi bi-collection-play me-2"></i>Quản lý Series</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" id="btnRefresh" type="button">
            <i class="bi bi-arrow-clockwise me-1"></i>Nạp lại
        </button>
        <button class="btn btn-primary" id="btnAdd" type="button">
            <i class="bi bi-plus-circle me-1"></i>Thêm series
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <input id="txtSearch" class="form-control" placeholder="Tìm theo tiêu đề..." />
            </div>
            <div class="col-md-3">
                <select id="slStatus" class="form-select">
                    <option value="">Trạng thái (Tất cả)</option>
                    <option value="ONGOING">ONGOING</option>
                    <option value="ENDED">ENDED</option>
                    <option value="DRAFT">DRAFT</option>
                </select>
            </div>
            <div class="col-md-3">
                <select id="slPremium" class="form-select">
                    <option value="">Premium (Tất cả)</option>
                    <option value="Y">Có</option>
                    <option value="N">Không</option>
                </select>
            </div>
            <div class="col-md-2">
                <select id="pageSize" class="form-select">
                    <option value="10">10 / trang</option>
                    <option value="20" selected>20 / trang</option>
                    <option value="50">50 / trang</option>
                    <option value="100">100 / trang</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table id="seriesTable" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;">ID</th>
                        <th>Tiêu đề</th>
                        <th class="text-nowrap">First Air</th>
                        <th class="text-nowrap">Last Air</th>
                        <th>Status</th>
                        <th>Premium</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div id="pagerWrap" class="mt-2"></div>
    </div>
</div>

<div class="modal fade" id="seriesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><span id="seriesModalTitle">Thêm series</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body">
                <form id="seriesForm" class="row g-3" onsubmit="return false;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="SeriesId" />

                    <div class="col-md-8">
                        <label class="form-label">Tiêu đề *</label>
                        <input class="form-control" id="Title" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Original Title</label>
                        <input class="form-control" id="OriginalTitle" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Overview</label>
                        <textarea class="form-control" id="Overview" rows="3"></textarea>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">First Air Date</label>
                        <input type="date" class="form-control" id="FirstAirDate" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Last Air Date</label>
                        <input type="date" class="form-control" id="LastAirDate" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="Status">
                            <option value="">--</option>
                            <option value="ONGOING">ONGOING</option>
                            <option value="ENDED">ENDED</option>
                            <option value="DRAFT">DRAFT</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Premium</label>
                        <select class="form-select" id="IsPremium">
                            <option value="N">Không</option>
                            <option value="Y">Có</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">IMDB ID</label>
                        <input class="form-control" id="ImdbId" placeholder="tt0903747" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">TMDB ID</label>
                        <input class="form-control" id="TmdbId" placeholder="1396" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Country</label>
                        <input class="form-control" id="CountryCode" placeholder="US, VN..." />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Language</label>
                        <input class="form-control" id="LanguageCode" placeholder="en, vi..." />
                    </div>

                    <div class="col-12">
                        <button class="btn btn-outline-info w-100" type="button" data-bs-toggle="collapse" data-bs-target="#sgPanel" aria-expanded="false">
                            <i class="bi bi-tags me-1"></i> Thể loại (SeriesGenre)
                        </button>
                        <div class="form-text">Sau khi lưu series thành công, bạn có thể gán thể loại ngay bên dưới.</div>
                    </div>
                </form>

                <div class="collapse mt-3" id="sgPanel">
                    <div class="border rounded p-3">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">SeriesId</label>
                                <input id="SG_SeriesId" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Chọn thể loại</label>
                                <select id="SG_Genre" class="form-select">
                                    <option value="">-- Chọn thể loại --</option>
                                </select>
                            </div>

                            <div class="col-md-3">
                                <button class="btn btn-primary w-100" id="btnSGAdd" type="button">
                                    <i class="bi bi-plus-circle me-1"></i><span class="__text">Thêm thể loại</span>
                                </button>
                            </div>
                        </div>

                        <div class="mt-3 d-flex gap-2">
                            <button class="btn btn-outline-secondary d-none" id="btnSGCancel" type="button">
                                <i class="bi bi-x-circle me-1"></i>Hủy sửa
                            </button>
                        </div>

                        <hr class="my-3" />

                        <div class="small text-secondary mb-2">Đang gán:</div>

<div class="table-responsive">
    <table class="table table-hover align-middle" id="SG_Table">
        <thead>
            <tr>
                <th style="width: 120px;">SeriesId</th>
                <th style="width: 120px;">GenreId</th>
                <th>Tên thể loại</th>
                <th style="width: 160px;">Slug</th>
                <th class="text-end" style="width: 160px;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="SG_Selected"></tbody>
    </table>
</div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Hủy</button>
                <button class="btn btn-primary" id="btnSave" type="button">
                    <i class="bi bi-save me-1"></i>Lưu series
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script>
        (function () {
            const urls = {
                series: {
                    getAll: '@urlGetAll',
                    add: '@urlAdd',
                    update: '@urlUpdate',
                    delete: '@urlDelete'
                },
                genres: {
                    getAll: '@urlGenresGetAll'
                },
                sg: {
                    getBy: '@urlSGGetBySeries',
                    add: '@urlSGAdd',
                    delete: '@urlSGDelete'
                }
            };

            const $overlay = $('#__loadingOverlay');
            const $toast = $('#__toastMessage');
            const $tbody = $('#seriesTable tbody');
            const $pager = $('#pagerWrap');
            const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('seriesModal'));

            const $sgGenre = $('#SG_Genre');
            const $sgSelected = $('#SG_Selected');
            const $btnSGAdd = $('#btnSGAdd');
            const $btnSGCancel = $('#btnSGCancel');

            let cache = [];
            let filtered = [];
            let page = 1;

            let genresCache = [];
            let seriesGenreCache = [];
            let sgEditingGenreId = null;

            const showLoading = () => $overlay.fadeIn(80);
            const hideLoading = () => $overlay.fadeOut(120);

            function showToast(msg, ok = true, ms = 2600) {
                $toast.text(msg || '')
                    .removeClass('success error')
                    .addClass(ok ? 'success' : 'error')
                    .fadeIn(120);

                setTimeout(() => $toast.fadeOut(150), ms);
            }

            function pickList(res) {
                const d = res?.data ?? res?.Data;
                if (!d) {
                    if (Array.isArray(res)) return res;
                    return [];
                }
                if (Array.isArray(d)) return d;
                if (Array.isArray(d.table)) return d.table;
                if (Array.isArray(d.Table)) return d.Table;
                return [];
            }

            function gv(o, ...keys) {
                for (const k of keys) {
                    if (o?.[k] !== undefined && o?.[k] !== null) return o[k];
                }
                return undefined;
            }

            function getSeriesId(row) {
                return gv(row, 'SeriesId', 'seriesId', 'serieS_ID', 'Seriesid');
            }

            function getSeriesIdFromResponse(res) {
                return (
                    res?.data?.SeriesId ??
                    res?.data?.seriesId ??
                    res?.SeriesId ??
                    res?.seriesId ??
                    null
                );
            }

            function toDate10(v) {
                if (!v) return '';
                try {
                    const s = String(v);
                    if (/^\d{4}-\d{2}-\d{2}/.test(s)) return s.substring(0, 10);
                    const d = new Date(s);
                    if (!isNaN(d)) return d.toISOString().substring(0, 10);
                } catch { }
                return '';
            }

            function date0(d) {
                return d ? (d + 'T00:00:00') : null;
            }

            function bindSeriesId(id) {
                $('#SeriesId').val(id || '');
                $('#SG_SeriesId').val(id || '');
            }

            function currentSeriesId() {
                const s = ($('#SeriesId').val() || '').trim();
                return s ? +s : null;
            }

            function setGenrePanelEnabled(enabled) {
                $btnSGAdd.prop('disabled', !enabled);
                $sgGenre.prop('disabled', !enabled);

                if (!enabled) {
                    $('#SG_SeriesId').val('');
                    $sgSelected.html('<span class="text-secondary">Hãy lưu Series trước để quản lý thể loại.</span>');
                }
            }

            function paginate(list, pageNo, size) {
                const total = list.length;
                const last = Math.max(1, Math.ceil(total / size));
                pageNo = Math.min(Math.max(1, pageNo), last);
                const start = (pageNo - 1) * size;
                return {
                    page: pageNo,
                    size,
                    total,
                    last,
                    items: list.slice(start, start + size)
                };
            }

            function renderPager(state) {
                const { page: p, last, total } = state;
                const btn = (label, target, disabled) =>
                    `<li class="page-item ${disabled ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${target}">${label}</a>
                     </li>`;

                $pager.html(`
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div class="small text-secondary">Tổng: <b>${total}</b> • Trang <b>${p}</b>/<b>${last}</b></div>
                        <ul class="pagination m-0">
                            ${btn('«', 1, p <= 1)}
                            ${btn('‹', p - 1, p <= 1)}
                            ${btn(p, p, true)}
                            ${btn('›', p + 1, p >= last)}
                            ${btn('»', last, p >= last)}
                        </ul>
                    </div>
                `);

                $pager.find('a.page-link').on('click', function (e) {
                    e.preventDefault();
                    const next = +$(this).data('page');
                    if (Number.isFinite(next)) {
                        page = next;
                        renderTablePage();
                    }
                });
            }

            function applyFilter() {
                const q = ($('#txtSearch').val() || '').trim().toLowerCase();
                const st = ($('#slStatus').val() || '').trim();
                const pm = ($('#slPremium').val() || '').trim();

                filtered = cache.filter(s => {
                    const title = (gv(s, 'title', 'Title') || '').toLowerCase();
                    const status = gv(s, 'status', 'Status') || '';
                    const rawPremium = gv(s, 'IsPremiumYN', 'iS_PREMIUM', 'IsPremium', 'isPremium', 'is_premium') ?? 'N';
                    const premiumYN = typeof rawPremium === 'string'
                        ? rawPremium.toUpperCase()
                        : (rawPremium ? 'Y' : 'N');

                    return (!q || title.includes(q))
                        && (!st || status === st)
                        && (!pm || premiumYN === pm);
                });
            }

            function renderTablePage() {
                const size = +($('#pageSize').val() || 20);
                const st = paginate(filtered, page, size);

                const rows = st.items.map(s => {
                    const id = getSeriesId(s);
                    const title = gv(s, 'title', 'Title') || '';
                    const firstAir = toDate10(gv(s, 'firstAirDate', 'FirstAirDate', 'firsT_AIR_DATE'));
                    const lastAir = toDate10(gv(s, 'lastAirDate', 'LastAirDate', 'lasT_AIR_DATE'));
                    const status = gv(s, 'status', 'Status') || '';
                    const rawPremium = gv(s, 'IsPremiumYN', 'iS_PREMIUM', 'IsPremium', 'isPremium') ?? 'N';
                    const premiumYN = typeof rawPremium === 'string'
                        ? rawPremium.toUpperCase()
                        : (rawPremium ? 'Y' : 'N');

                    return `
                        <tr>
                            <td class="text-muted">${id ?? ''}</td>
                            <td class="fw-semibold">${title}</td>
                            <td>${firstAir || ''}</td>
                            <td>${lastAir || ''}</td>
                            <td><span class="chip">${status}</span></td>
                            <td><span class="chip">${premiumYN === 'Y' ? 'Có' : 'Không'}</span></td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-secondary btn-edit" data-id="${id}">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger btn-del" data-id="${id}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');

                $tbody.html(rows || `<tr><td colspan="7" class="text-center text-secondary">Không có dữ liệu</td></tr>`);
                renderPager(st);
            }

            function render() {
                applyFilter();
                page = 1;
                renderTablePage();
            }

            function reloadAll() {
                showLoading();
                $.get(urls.series.getAll)
                    .done(res => {
                        cache = pickList(res);
                        render();
                    })
                    .fail(xhr => {
                        showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối.', false);
                    })
                    .always(hideLoading);
            }

            function resetGenreEditor() {
                sgEditingGenreId = null;
                $btnSGCancel.addClass('d-none');
                $btnSGAdd.find('span.__text').text('Thêm thể loại');
                $sgGenre.val('');
            }

            function openAdd() {
                $('#seriesModalTitle').text('Thêm series');
                $('#seriesForm')[0].reset();
                $('#IsPremium').val('N');
                $('#Status').val('');
                bindSeriesId('');
                resetGenreEditor();
                setGenrePanelEnabled(false);
                loadGenresOnce();
                modal.show();
            }

            function openEdit(id) {
                const s = cache.find(x => String(getSeriesId(x)) === String(id));
                if (!s) {
                    showToast('Không tìm thấy series.', false);
                    return;
                }

                $('#seriesModalTitle').text('Chỉnh sửa series');
                bindSeriesId(getSeriesId(s));

                $('#Title').val(gv(s, 'title', 'Title') || '');
                $('#OriginalTitle').val(gv(s, 'originalTitle', 'OriginalTitle', 'originaL_TITLE') || '');
                $('#Overview').val(gv(s, 'overview', 'Overview') || '');
                $('#FirstAirDate').val(toDate10(gv(s, 'firstAirDate', 'FirstAirDate', 'firsT_AIR_DATE')));
                $('#LastAirDate').val(toDate10(gv(s, 'lastAirDate', 'LastAirDate', 'lasT_AIR_DATE')));
                $('#Status').val(gv(s, 'status', 'Status') || '');

                const rawPremium = gv(s, 'IsPremiumYN', 'iS_PREMIUM', 'IsPremium', 'isPremium') ?? 'N';
                const premiumYN = typeof rawPremium === 'string'
                    ? rawPremium.toUpperCase()
                    : (rawPremium ? 'Y' : 'N');
                $('#IsPremium').val(premiumYN);

                $('#ImdbId').val(gv(s, 'imdbId', 'ImdbId', 'imdB_ID') || '');
                $('#TmdbId').val(gv(s, 'tmdbId', 'TmdbId', 'tmdB_ID') || '');
                $('#CountryCode').val(gv(s, 'countryCode', 'CountryCode', 'countrY_CODE') || '');
                $('#LanguageCode').val(gv(s, 'languageCode', 'LanguageCode', 'languagE_CODE') || '');

                resetGenreEditor();
                setGenrePanelEnabled(true);
                loadGenresOnce().then(() => loadSeriesGenres(currentSeriesId()));
                modal.show();
            }

            function buildSeriesPayload(isEdit) {
                const idStr = ($('#SeriesId').val() || '').trim();

                const payload = {
                    Title: ($('#Title').val() || '').trim(),
                    OriginalTitle: ($('#OriginalTitle').val() || '').trim() || null,
                    Overview: ($('#Overview').val() || '').trim() || null,
                    FirstAirDate: date0($('#FirstAirDate').val()),
                    LastAirDate: date0($('#LastAirDate').val()),
                    Status: ($('#Status').val() || '').trim() || 'ONGOING',
                    IsPremium: (($('#IsPremium').val() || 'N').toUpperCase() === 'Y'),
                    ImdbId: ($('#ImdbId').val() || '').trim() || null,
                    TmdbId: ($('#TmdbId').val() || '').trim() || null,
                    CountryCode: ($('#CountryCode').val() || '').trim() || null,
                    LanguageCode: ($('#LanguageCode').val() || '').trim() || null
                };

                if (isEdit) payload.SeriesId = +idStr;
                return payload;
            }

            function saveSeries() {
                const anti = $('input[name="__RequestVerificationToken"]').val();
                const idStr = ($('#SeriesId').val() || '').trim();
                const isEdit = !!idStr;
                const url = isEdit ? urls.series.update : urls.series.add;

                const title = ($('#Title').val() || '').trim();
                if (!title) {
                    showToast('Vui lòng nhập tiêu đề.', false);
                    return;
                }

                const payload = buildSeriesPayload(isEdit);

                showLoading();
                $.ajax({
                    url: url,
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    headers: anti ? { "RequestVerificationToken": anti } : {},
                    data: JSON.stringify(payload)
                })
                .done(res => {
                    const ok = res && (res.success === true || res.Success === true || res.code === '200');
                    if (!ok) {
                        showToast(res?.message || 'Thao tác thất bại.', false);
                        return;
                    }

                    if (isEdit) {
                        showToast('Đã cập nhật series', true);
                        reloadAll();
                        return;
                    }

                    const newSeriesId = getSeriesIdFromResponse(res);
                    if (!newSeriesId) {
                        showToast('Đã lưu series nhưng server chưa trả về SeriesId.', false);
                        reloadAll();
                        return;
                    }

                    bindSeriesId(newSeriesId);
                    setGenrePanelEnabled(true);
                    showToast(`Đã thêm series #${newSeriesId}. Bây giờ có thể thêm thể loại.`, true);
                    loadSeriesGenres(newSeriesId);
                    reloadAll();
                })
                .fail(xhr => {
                    showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối.', false);
                })
                .always(hideLoading);
            }

            function removeSeries(id) {
                if (!confirm(`Xóa series #${id}?`)) return;

                showLoading();
                $.ajax({
                    url: urls.series.delete,
                    type: 'GET',
                    data: { id }
                })
                .done(res => {
                    const ok = res && (res.success === true || res.code === '200');
                    if (ok) {
                        showToast('Đã xóa', true);
                        reloadAll();
                    } else {
                        showToast(res?.message || 'Xóa thất bại.', false);
                    }
                })
                .fail(xhr => {
                    showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối.', false);
                })
                .always(hideLoading);
            }

            function loadGenresOnce() {
                if (genresCache.length) {
                    renderGenreDropdown();
                    return Promise.resolve(genresCache);
                }

                return $.get(urls.genres.getAll)
                    .done(res => {
                        genresCache = pickList(res) || [];
                        renderGenreDropdown();
                    })
                    .fail(() => {
                        $sgGenre.html('<option value="">(Không tải được genres)</option>');
                    });
            }

            function renderGenreDropdown() {
                const opts = ['<option value="">-- Chọn thể loại --</option>'].concat(
                    genresCache.map(g => {
                        const id = gv(g, 'GenreId', 'genreId', 'genrE_ID', 'Id', 'id');
                        const name = gv(g, 'GenreName', 'genreName', 'genrE_NAME', 'Name', 'name') || ('#' + id);
                        return `<option value="${id}">${name}</option>`;
                    })
                );

                $sgGenre.html(opts.join(''));
            }

            function loadSeriesGenres(seriesId) {
                if (!seriesId) {
                    $sgSelected.html('<span class="text-secondary">Chưa có SeriesId.</span>');
                    return Promise.resolve();
                }

                return $.get(urls.sg.getBy, { id: seriesId })
                    .done(res => {
                        seriesGenreCache = pickList(res) || [];
                        renderSeriesGenreChips();
                    })
                    .fail(() => {
                        seriesGenreCache = [];
                        renderSeriesGenreChips();
                    });
            }

           function renderSeriesGenreChips() {
    const sid = currentSeriesId();

    const rows = (seriesGenreCache || []).map(g => {
        const gid = gv(g, 'GenreId', 'genreId', 'genre_id', 'genrE_ID', 'Id', 'id');
        const gname = gv(g, 'GenreName', 'genreName', 'genre_name', 'genrE_NAME', 'Name', 'name') || ('#' + gid);
        const slug = gv(g, 'Slug', 'slug') || '';

        return `
            <tr>
                <td>${sid ?? ''}</td>
                <td>${gid ?? ''}</td>
                <td>${gname}</td>
                <td>${slug}</td>
                <td class="text-end">
                    <div class="btn-group">
                        <button class="btn btn-sm btn-outline-secondary btn-sg-edit" data-gid="${gid}" type="button" title="Sửa">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger btn-sg-del" data-gid="${gid}" type="button" title="Gỡ">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `;
    }).join('');

    $('#SG_Selected').html(
        rows || `<tr><td colspan="5" class="text-center text-secondary">Chưa có thể loại</td></tr>`
    );
}

            function addSeriesGenre() {
                const sid = currentSeriesId();
                const gid = +($sgGenre.val() || 0);

                if (!sid) {
                    showToast('Hãy lưu series trước.', false);
                    return;
                }

                if (!gid) {
                    showToast('Chọn thể loại.', false);
                    return;
                }

                const existed = seriesGenreCache.some(x => String(gv(x, 'GenreId', 'genreId', 'genrE_ID')) === String(gid));
                if (existed) {
                    showToast('Thể loại đã tồn tại.', false);
                    return;
                }

                const anti = $('input[name="__RequestVerificationToken"]').val();
                const payload = { SeriesId: sid, GenreId: gid };
                console.log(urls.sg.add,payload);
                showLoading();
                $.ajax({
                    url: urls.sg.add,
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    headers: anti ? { "RequestVerificationToken": anti } : {},
                    data: JSON.stringify(payload)
                })
                .done(res => {
                    const ok = res && (res.success === true || res.Success === true || res.code === '200');
                    if (ok) {
                        showToast('Đã thêm thể loại', true);
                        resetGenreEditor();
                        loadSeriesGenres(sid);
                    } else {
                        showToast(res?.message || 'Không thêm được.', false);
                    }
                })
                .fail(xhr => {
                    showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối.', false);
                })
                .always(hideLoading);
            }

            function deleteSeriesGenre(gid) {
                const sid = currentSeriesId();
                if (!sid || !gid) return;

                const anti = $('input[name="__RequestVerificationToken"]').val();
                const payload = { SeriesId: sid, GenreId: gid };

                showLoading();
                $.ajax({
                    url: urls.sg.delete,
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    headers: anti ? { "RequestVerificationToken": anti } : {},
                    data: JSON.stringify(payload)
                })
                .done(res => {
                    const ok = res && (res.success === true || res.Success === true || res.code === '200');
                    if (ok) {
                        seriesGenreCache = seriesGenreCache.filter(x => String(gv(x, 'GenreId', 'genreId', 'genrE_ID')) !== String(gid));
                        renderSeriesGenreChips();
                        showToast('Đã gỡ thể loại', true);
                    } else {
                        showToast(res?.message || 'Gỡ thất bại.', false);
                    }
                })
                .fail(xhr => {
                    showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối.', false);
                })
                .always(hideLoading);
            }

            function startEditSeriesGenre(gid) {
                sgEditingGenreId = +gid;
                $btnSGCancel.removeClass('d-none');
                $btnSGAdd.find('span.__text').text('Cập nhật');
                $sgGenre.val(String(gid));
            }

            function cancelEditSeriesGenre() {
                resetGenreEditor();
            }

            function updateSeriesGenre() {
                const sid = currentSeriesId();
                const oldGid = sgEditingGenreId;
                const newGid = +($sgGenre.val() || 0);

                if (!sid) {
                    showToast('Chưa có SeriesId.', false);
                    return;
                }

                if (!newGid) {
                    showToast('Chọn thể loại mới.', false);
                    return;
                }

                if (oldGid === newGid) {
                    showToast('Không có thay đổi.', false);
                    return;
                }

                const existed = seriesGenreCache.some(x => String(gv(x, 'GenreId', 'genreId', 'genrE_ID')) === String(newGid));
                if (existed) {
                    showToast('Thể loại này đã tồn tại.', false);
                    return;
                }

                const anti = $('input[name="__RequestVerificationToken"]').val();

                showLoading();
                $.ajax({
                    url: urls.sg.delete,
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    headers: anti ? { "RequestVerificationToken": anti } : {},
                    data: JSON.stringify({ SeriesId: sid, GenreId: oldGid })
                })
                .done(() => {
                    $.ajax({
                        url: urls.sg.add,
                        type: 'POST',
                        contentType: 'application/json; charset=utf-8',
                        headers: anti ? { "RequestVerificationToken": anti } : {},
                        data: JSON.stringify({ SeriesId: sid, GenreId: newGid })
                    })
                    .done(res => {
                        const ok = res && (res.success === true || res.Success === true || res.code === '200');
                        if (ok) {
                            showToast('Đã cập nhật thể loại', true);
                            resetGenreEditor();
                            loadSeriesGenres(sid);
                        } else {
                            showToast(res?.message || 'Cập nhật thất bại.', false);
                        }
                    })
                    .fail(xhr => {
                        showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối khi thêm lại.', false);
                    })
                    .always(hideLoading);
                })
                .fail(xhr => {
                    hideLoading();
                    showToast(xhr?.responseJSON?.message || xhr?.responseText || 'Lỗi kết nối khi xóa.', false);
                });
            }

            $('#btnRefresh').on('click', reloadAll);
            $('#btnAdd').on('click', openAdd);
            $('#btnSave').on('click', saveSeries);

            $('#txtSearch, #slStatus, #slPremium').on('input change', function () {
                render();
            });

            $('#pageSize').on('change', function () {
                page = 1;
                renderTablePage();
            });

            $tbody.on('click', '.btn-edit', function () {
                openEdit($(this).data('id'));
            });

            $tbody.on('click', '.btn-del', function () {
                removeSeries($(this).data('id'));
            });

            document.getElementById('sgPanel')?.addEventListener('shown.bs.collapse', function () {
                const sid = currentSeriesId();
                loadGenresOnce().then(() => {
                    if (sid) {
                        loadSeriesGenres(sid);
                    }
                });
            });

            $btnSGAdd.on('click', function () {
                if (sgEditingGenreId) updateSeriesGenre();
                else addSeriesGenre();
            });

            $btnSGCancel.on('click', cancelEditSeriesGenre);

            $sgSelected.on('click', '.btn-sg-del', function () {
                deleteSeriesGenre(+$(this).data('gid'));
            });

            $sgSelected.on('click', '.btn-sg-edit', function () {
                startEditSeriesGenre(+$(this).data('gid'));
            });

            reloadAll();
            loadGenresOnce();
            setGenrePanelEnabled(false);
        })();
    </script>
}